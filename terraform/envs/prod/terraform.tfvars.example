project_name = "orderbook-pipeline"

oci_tenancy_ocid     = "ocid1.tenancy.oc1.."
oci_user_ocid        = "ocid1.user.oc1.."
oci_fingerprint      = "aa:bb:cc:..."
oci_private_key_path = "~/.oci/oci_api_key.pem"
oci_region           = "us-chicago-1"
oci_compartment_ocid = "ocid1.compartment.oc1.."
oci_admin_cidr       = "YOUR_IP/32"
oci_ssh_public_key   = "ssh-ed25519 AAAA..."

cockroach_api_key        = "..."
cockroach_cluster_name   = "orderbook-crdb"
cockroach_cloud_provider = "AWS"
cockroach_region         = "us-east-1"
cockroach_delete_protection = false

upstash_email   = "you@example.com"
upstash_api_key = "..."
upstash_region  = "us-east-1"

redis_cloud_api_key    = "your-redis-cloud-api-key"     # from Redis Cloud console → Account Settings → API Keys
redis_cloud_secret_key = "your-redis-cloud-secret-key"
redis_cloud_region     = "us-central1"
redis_cloud_provider   = "GCP"
redis_cloud_password   = "your-database-password"

enable_redpanda            = true
redpanda_client_id          = "..."
redpanda_client_secret      = "..."
redpanda_resource_group_name = "orderbook-rg"
# If resource group already exists, set its ID and Terraform will not create one.
# redpanda_existing_resource_group_id = "..."
redpanda_cluster_name       = "orderbook-serverless"
# If cluster already exists, set its ID and Terraform will not create one.
# redpanda_existing_cluster_id = "..."
redpanda_serverless_region  = "us-east-1"
redpanda_kafka_user         = "orderbook_app"
redpanda_kafka_password     = "..."
redpanda_topic_prefix       = "orderbook"

# Set enable_redpanda=false to skip Redpanda provisioning/reads temporarily.
