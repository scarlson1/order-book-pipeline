# CockroachDB
DATABASE_URL=postgresql://<sql-user>:<url-encoded-sql-password>@<cluster-host>:26257/defaultdb?sslmode=require
POSTGRES_HOST=<cluster-host>
POSTGRES_PORT=26257
POSTGRES_DB=defaultdb
POSTGRES_USER=<sql-user>
POSTGRES_PASSWORD=<sql-password>
POSTGRES_SSLMODE=require
# or: POSTGRES_SSLMODE=verify-full
# POSTGRES_SSLROOTCERT=/app/certs/ca.crt
# POSTGRES_SSLCERT=/app/certs/client.crt
# POSTGRES_SSLKEY=/app/certs/client.key

# Upstash Redis
REDIS_HOST=<upstash-host>
REDIS_PORT=6379
REDIS_PASSWORD=<upstash-password>
REDIS_SSL=true
REDIS_URL=<full-upstash-connection-url>
# Per-symbol snapshot write debounce for Redis command budgeting.
# 60s ~= 43,200 writes/symbol/month. Use with 60s dashboard reads to stay <100k total.
REDIS_SNAPSHOT_MIN_WRITE_INTERVAL_SECONDS=60 # temporarily set to 300 in github secret so limit isn't exhausted in a couple days

# Redpanda Serverless
REDPANDA_BOOTSTRAP_SERVERS=<bootstrap1:9092,bootstrap2:9092>
REDPANDA_SERVICE=<bootstrap-without-port>
REDPANDA_TOPIC_PREFIX=orderbook
REDPANDA_SECURITY_PROTOCOL=SASL_SSL
REDPANDA_SASL_MECHANISM=SCRAM-SHA-256
REDPANDA_USERNAME=<redpanda user>
REDPANDA_PASSWORD=<redpanda password>
REDPANDA_SSL_CHECK_HOSTNAME=true
REDPANDA_KAFKA_PORT=9092
# REDPANDA_SSL_CAFILE=/app/certs/ca.pem

# Flink
FLINK_HOST=flink-jobmanager
FLINK_PARALLELISM=1
FLINK_PORT=8081

# App config
BINANCE_WS_URL=wss://stream.binance.us:9443/ws
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
DEPTH_LEVELS=20
UPDATE_SPEED=1000ms
CALCULATE_DEPTH=10
ROLLING_WINDOW_SECONDS=60
CALCULATE_VELOCITY=true
ALERT_THRESHOLD_HIGH=0.70
ALERT_THRESHOLD_MEDIUM=0.50
SPREAD_ALERT_MULTIPLIER=2.0
VELOCITY_THRESHOLD=0.05
LOG_LEVEL=INFO
LOG_FILE=/app/logs/orderbook.log
ENVIRONMENT=production
